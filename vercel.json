{
  "redirects": [
    {
      "source": "/verify-email",
      "destination": "/verify-email-code",
      "permanent": true
    },
    {
      "source": "/verify-email/:path*",
      "destination": "/verify-email-code",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/telegram-daily-report",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/telegram-weekly-report",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/trial-recovery",
      "schedule": "0 */6 * * *"
    }
  ]
}

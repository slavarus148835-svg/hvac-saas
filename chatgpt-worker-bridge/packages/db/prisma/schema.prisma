generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id           String   @id @default(cuid())
  type         String
  payloadJson  String
  status       String
  resultJson   String?
  errorText    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
}
